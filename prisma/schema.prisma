datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model AccountState {
  id            Int      @id @default(autoincrement())
  account       String   @unique
  balance       Float
  equity        Float
  dailyProfit   Float
  floatingPl    Float
  totalProfit   Float
  maxDrawdown   Float
  status        String   // "RUNNING" or "PAUSED"
  lastUpdated   DateTime @updatedAt
  newsActive    Boolean  @default(false)
  newsFrozen    Boolean  @default(false)
  newsName      String   @default("")
  trailingActive Boolean  @default(false)
  trailingPeak   Float    @default(0.0)
  ddReached10    Boolean  @default(false)
  ddReached20    Boolean  @default(false)
  brlRate        Float    @default(5.20)
  equityCycleBase      Float    @default(0.0)
  equityCycleTargetPct Float    @default(5.0)
  softStopLimit        Float    @default(400.0)
  loteBase             Float    @default(0.012)
  takeProfitLimit      Float    @default(1.50)
  buySosScheduled      Boolean  @default(false)
  sellSosScheduled     Boolean  @default(false)
}

model ActiveTrade {
  id            Int      @id @default(autoincrement())
  account       String
  ticket        String   @unique
  symbol        String
  type          String   // "BUY" or "SELL"
  volume        Float
  entryPrice    Float
  currentPrice  Float
  currentProfit Float
  magicNumber   Int
  tp            Float?
  sl            Float?
  createdAt     DateTime @default(now())
}

model PerformanceHistory {
  id            Int      @id @default(autoincrement())
  account       String
  date          DateTime
  profit        Float
  balance       Float
  equity        Float?
  gain          Float    @default(0.0)
  loss          Float    @default(0.0)

  @@unique([account, date])
}

model CommandQueue {
  id            Int       @id @default(autoincrement())
  account       String
  command       String    // "PAUSE", "RESUME", "PANIC_LOCAL", "PANIC_GLOBAL"
  symbol        String    // e.g. "EURUSD" or ""
  status        String    // "PENDING", "EXECUTED"
  createdAt     DateTime  @default(now())
  executedAt    DateTime?
}
